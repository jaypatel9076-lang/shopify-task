{% comment %}
  Custom AJAX cart drawer. This does not use Dawn's cart drawer markup.

  Usage:
  {% render 'custom-ajax-cart-drawer' %}
{% endcomment %}

<custom-cart-drawer
  class="custom-cart-drawer{% if cart == empty %} is-empty{% endif %}"
  data-cart-url="{{ routes.cart_url }}"
  data-cart-change-url="{{ routes.cart_change_url }}"
  data-cart-update-url="{{ routes.cart_update_url }}"
  data-item-singular="{{ settings.custom_cart_drawer_item_singular | escape }}"
  data-item-plural="{{ settings.custom_cart_drawer_item_plural | escape }}"
  data-remove-label="{{ settings.custom_cart_drawer_remove_label | escape }}"
  data-decrease-label="{{ settings.custom_cart_drawer_decrease_label | escape }}"
  data-increase-label="{{ settings.custom_cart_drawer_increase_label | escape }}"
  data-quantity-label="{{ settings.custom_cart_drawer_quantity_label | escape }}"
  data-loading-text="{{ settings.custom_cart_drawer_loading_text | escape }}"
  data-update-text="{{ settings.custom_cart_drawer_update_text | escape }}"
  data-remove-text="{{ settings.custom_cart_drawer_remove_text | escape }}"
  data-updated-text="{{ settings.custom_cart_drawer_updated_text | escape }}"
  data-removed-text="{{ settings.custom_cart_drawer_removed_text | escape }}"
>
  <button
    class="custom-cart-drawer__overlay"
    type="button"
    data-custom-cart-close
    aria-label="{{ 'accessibility.close' | t }}"
  ></button>

  <aside
    id="CustomCartDrawer"
    class="custom-cart-drawer__panel gradient color-{{ settings.cart_color_scheme }}"
    role="dialog"
    aria-modal="true"
    aria-labelledby="CustomCartDrawerTitle"
    tabindex="-1"
  >
    <header class="custom-cart-drawer__header">
      <div>
        <h2 id="CustomCartDrawerTitle" class="custom-cart-drawer__title">
          {{ settings.custom_cart_drawer_heading | escape }}
        </h2>
        <p class="custom-cart-drawer__count" data-custom-cart-count>
          {{ cart.item_count }}
          {% if cart.item_count == 1 %}
            {{ settings.custom_cart_drawer_item_singular | escape }}
          {% else %}
            {{ settings.custom_cart_drawer_item_plural | escape }}
          {% endif %}
        </p>
      </div>
      <button class="custom-cart-drawer__close" type="button" data-custom-cart-close aria-label="{{ 'accessibility.close' | t }}">
        <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
      </button>
    </header>

    <div class="custom-cart-drawer__body">
      <div class="custom-cart-drawer__loading" data-custom-cart-loading hidden>
        {%- render 'loading-spinner' -%}
      </div>
      <div class="custom-cart-drawer__items" data-custom-cart-items></div>
      <div class="custom-cart-drawer__empty" data-custom-cart-empty hidden>
        <h3 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h3>
        <a href="{{ routes.all_products_collection_url }}" class="button">{{ 'general.continue_shopping' | t }}</a>
      </div>
    </div>

    <p class="visually-hidden" role="status" aria-live="polite" data-custom-cart-status></p>
    <div class="custom-cart-drawer__error" role="alert" data-custom-cart-error></div>

    <footer class="custom-cart-drawer__footer" data-custom-cart-footer>
      <div class="custom-cart-drawer__totals" role="status">
        <h3>{{ 'sections.cart.estimated_total' | t }}</h3>
        <p data-custom-cart-total>{{ cart.total_price | money_with_currency }}</p>
      </div>
      <small class="tax-note caption-large rte">
        {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
      </small>

      <div class="custom-cart-drawer__ctas">
        {%- if settings.custom_cart_drawer_show_view_cart -%}
          <a class="button button--secondary" href="{{ routes.cart_url }}">
            {{ settings.custom_cart_drawer_view_cart_label | escape }}
          </a>
        {%- endif -%}
        <form action="{{ routes.cart_url }}" method="post">
          <button class="button" name="checkout" type="submit" data-custom-cart-checkout {% if cart == empty %}disabled{% endif %}>
            {{ 'sections.cart.checkout' | t }}
          </button>
        </form>
      </div>
    </footer>
  </aside>
</custom-cart-drawer>
