{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-filterable-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'filterable-collection.js' | asset_url }}" defer="defer"></script>

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign active_tag_handles = ''
  for tag in current_tags
    assign active_tag_handles = active_tag_handles | append: tag | handleize | append: ','
  endfor
-%}

<filterable-collection
  class="filterable-collection section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
  data-collection-url="{{ collection.url }}"
>
  {%- paginate collection.products by section.settings.products_per_page -%}
    <div class="page-width">
      <form class="filterable-collection__controls" data-filterable-form>
        <div class="filterable-collection__header">
          <div>
            <h2 class="filterable-collection__heading {{ section.settings.heading_size }}">
              {{ section.settings.heading | default: collection.title | escape }}
            </h2>
            <p class="filterable-collection__summary caption-large" data-filterable-count>
              {{ collection.products_count }} products
            </p>
          </div>
          <button type="button" class="link underlined-link" data-filterable-clear>Clear filters</button>
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="filterable-collection__groups">
            {%- for block in section.blocks -%}
              {%- liquid
                assign configured_tags = block.settings.tags | split: ','
              -%}
              <fieldset class="filterable-collection__fieldset" {{ block.shopify_attributes }}>
                <legend class="filterable-collection__legend">{{ block.settings.label | escape }}</legend>
                <div class="filterable-collection__tag-list">
                  {%- for configured_tag in configured_tags -%}
                    {%- liquid
                      assign tag_label = configured_tag | strip
                      assign tag_value = tag_label | handleize
                      assign active_token = tag_value | append: ','
                    -%}
                    {%- if tag_label != blank -%}
                      <label class="filterable-collection__tag">
                        <input
                          type="checkbox"
                          value="{{ tag_value }}"
                          data-filter-tag
                          {% if active_tag_handles contains active_token %}
                            checked
                          {% endif %}
                        >
                        <span class="filterable-collection__tag-label">{{ tag_label | escape }}</span>
                      </label>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="filterable-collection__sort">
          <label class="filterable-collection__sort-label" for="FilterableSort-{{ section.id }}">Sort by</label>
          <div class="select">
            <select
              id="FilterableSort-{{ section.id }}"
              class="select__select"
              name="sort_by"
              data-default-sort="{{ collection.default_sort_by }}"
            >
              <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>Featured</option>
              <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price, low to high</option>
              <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price, high to low</option>
              <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
            </select>
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </div>
        </div>

        <div class="filterable-collection__actions">
          <p class="filterable-collection__status caption-large" role="status" aria-live="polite" data-filterable-status></p>
        </div>
      </form>

      <div class="filterable-collection__grid-wrap" data-filterable-results>
        <div class="filterable-collection__loading">
          {%- render 'loading-spinner' -%}
        </div>

        {%- if collection.products.size == 0 -%}
          <div class="filterable-collection__empty">
            <h3 class="h2">No products found</h3>
            <p>Try removing a filter or choosing a different sort option.</p>
          </div>
        {%- else -%}
          <ul
            id="product-grid"
            data-id="{{ section.id }}"
            class="filterable-collection__grid grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
          >
            {%- for product in collection.products -%}
              {%- liquid
                assign lazy_load = false
                if forloop.index > 2
                  assign lazy_load = true
                endif
              -%}
              <li class="grid__item">
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  lazy_load: lazy_load,
                  quick_add: section.settings.quick_add,
                  section_id: section.id,
                  product_view_context: 'collection'
                %}
              </li>
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate, anchor: '' %}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</filterable-collection>

{% schema %}
{
  "name": "Filterable collection",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ]
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Mobile columns",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "adapt",
      "label": "Image ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_shape",
      "default": "default",
      "label": "Image shape",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "round",
          "label": "Round"
        },
        {
          "value": "arch",
          "label": "Arch"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show secondary image"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show rating"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "standard",
      "label": "Quick add",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "bulk",
          "label": "Bulk"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "tag_group",
      "name": "Tag group",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Group label",
          "default": "Color"
        },
        {
          "type": "textarea",
          "id": "tags",
          "label": "Tags",
          "default": "Black, White, Blue",
          "info": "Comma-separated product tags. Values are matched by tag handle."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Filterable collection",
      "blocks": [
        {
          "type": "tag_group"
        },
        {
          "type": "tag_group",
          "settings": {
            "label": "Size",
            "tags": "Small, Medium, Large"
          }
        }
      ]
    }
  ]
}
{% endschema %}
