{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-filterable-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'filterable-collection.js' | asset_url }}" defer="defer"></script>

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-spacing {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-spacing {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign target_collection = collection
  if target_collection == blank and section.settings.collection != blank
    assign target_collection = section.settings.collection
  endif
  if target_collection == blank
    assign target_collection = collections.all
  endif

  assign sort_by = target_collection.sort_by | default: target_collection.default_sort_by
  assign section_url = request.path
  if collection != blank
    assign section_url = target_collection.url
  endif
  assign is_collection_template = false
  if collection != blank
    assign is_collection_template = true
  endif
  assign native_filter_count = 0
  for filter in target_collection.filters
    if filter.type == 'list' or filter.type == 'boolean'
      assign native_filter_count = native_filter_count | plus: 1
    endif
  endfor
-%}

<filterable-collection
  class="filterable-collection section-{{ section.id }}-spacing gradient color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
  data-collection-url="{{ target_collection.url }}"
  data-section-url="{{ section_url }}"
  data-share-url="{{ section_url }}"
  data-filter-source="native"
  data-collection-template="{{ is_collection_template }}"
  data-loading-text="{{ section.settings.loading_text | escape }}"
  data-updated-text="{{ section.settings.updated_text | escape }}"
  data-error-text="{{ section.settings.error_text | escape }}"
>
  {%- paginate target_collection.products by section.settings.products_per_page -%}
    <div class="page-width section-{{ section.id }}-padding">
      <form
        class="filterable-collection__controls"
        aria-labelledby="FilterableCollectionHeading-{{ section.id }}"
        data-filterable-form
      >
        <div class="filterable-collection__header">
          <div>
            <h2
              id="FilterableCollectionHeading-{{ section.id }}"
              class="filterable-collection__heading {{ section.settings.heading_size }}"
            >
              {{ section.settings.heading | default: target_collection.title | escape }}
            </h2>
            <p class="filterable-collection__summary caption-large" data-filterable-count>
              {{ target_collection.products_count }}
              {% if target_collection.products_count == 1 %}
                {{ section.settings.product_count_singular | escape }}
              {% else %}
                {{ section.settings.product_count_plural | escape }}
              {% endif %}
            </p>
          </div>
          <button type="button" class="link underlined-link" data-filterable-clear>
            {{ section.settings.clear_filters_label | escape }}
          </button>
        </div>

        {%- if section.settings.show_filters and native_filter_count > 0 -%}
          <div class="filterable-collection__groups" aria-label="{{ section.settings.filter_group_label | escape }}">
            {%- for filter in target_collection.filters -%}
              {%- if filter.type == 'list' or filter.type == 'boolean' -%}
                <fieldset class="filterable-collection__fieldset">
                  <legend class="filterable-collection__legend">{{ filter.label | escape }}</legend>
                  <div class="filterable-collection__tag-list">
                    {%- for value in filter.values -%}
                      <label class="filterable-collection__tag">
                        <input
                          type="checkbox"
                          name="{{ filter.param_name }}"
                          value="{{ value.value }}"
                          data-native-filter
                          {% if value.active %}
                            checked
                          {% endif %}
                          {% if value.count == 0 and value.active == false %}
                            disabled
                          {% endif %}
                        >
                        <span class="filterable-collection__tag-label">
                          {{ value.label | escape }}
                          {%- if section.settings.show_filter_counts -%}
                            ({{ value.count }})
                          {%- endif -%}
                        </span>
                      </label>
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- elsif section.settings.show_filters and is_collection_template == false and target_collection.url != blank -%}
          <div
            class="filterable-collection__groups"
            aria-label="{{ section.settings.filter_group_label | escape }}"
            aria-live="polite"
            data-filterable-groups
          ></div>
        {%- elsif section.settings.show_filters -%}
          <p class="filterable-collection__status caption-large">
            {{ section.settings.no_filters_message | escape }}
          </p>
        {%- endif -%}

        {%- if section.settings.enable_sorting -%}
          <div class="filterable-collection__sort">
            <label class="filterable-collection__sort-label" for="FilterableSort-{{ section.id }}">
              {{ section.settings.sort_label | escape }}
            </label>
            <div class="select">
              <select
                id="FilterableSort-{{ section.id }}"
                class="select__select"
                name="sort_by"
                data-default-sort="{{ target_collection.default_sort_by }}"
              >
                <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>
                  {{ section.settings.sort_featured_label | escape }}
                </option>
                <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>
                  {{ section.settings.sort_price_ascending_label | escape }}
                </option>
                <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>
                  {{ section.settings.sort_price_descending_label | escape }}
                </option>
                <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>
                  {{ section.settings.sort_newest_label | escape }}
                </option>
              </select>
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </div>
          </div>
        {%- endif -%}

        <div class="filterable-collection__actions">
          <p class="filterable-collection__status caption-large" role="status" aria-live="polite" data-filterable-status></p>
        </div>
      </form>

      {%- if section.settings.show_active_filters -%}
        <div class="active-filters" data-active-filters>
          {%- for filter in target_collection.filters -%}
            {%- for value in filter.active_values -%}
              <a
                class="active-filter"
                href="{{ value.url_to_remove }}"
                aria-label="{{ section.settings.remove_filter_label | escape }}: {{ value.label | escape }}"
                data-filter-link
              >
                {{ value.label | escape }} <span aria-hidden="true">x</span>
              </a>
            {%- endfor -%}
          {%- endfor -%}

          {%- if target_collection.filters != empty -%}
            {%- assign has_active_filter = false -%}
            {%- for filter in target_collection.filters -%}
              {%- if filter.active_values.size > 0 -%}
                {%- assign has_active_filter = true -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if has_active_filter -%}
              <a
                class="active-filter clear-all"
                href="{{ section_url }}{% if sort_by != blank %}?sort_by={{ sort_by }}{% endif %}"
                data-filter-link
              >
                {{ section.settings.clear_all_label | escape }}
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="filterable-collection__grid-wrap" data-filterable-results>
        <div class="filterable-collection__loading">
          {%- render 'loading-spinner' -%}
        </div>

        {%- if target_collection.products.size == 0 -%}
          <div class="filterable-collection__empty">
            <h3 class="h2">{{ section.settings.empty_heading | escape }}</h3>
            <p>{{ section.settings.empty_text | escape }}</p>
          </div>
        {%- else -%}
          <ul
            id="product-grid"
            data-id="{{ section.id }}"
            class="filterable-collection__grid grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
          >
            {%- for product in target_collection.products -%}
              {%- liquid
                assign lazy_load = false
                if forloop.index > 2
                  assign lazy_load = true
                endif
              -%}
              <li class="grid__item">
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  lazy_load: lazy_load,
                  quick_add: section.settings.quick_add,
                  section_id: section.id,
                  product_view_context: 'collection'
                %}
              </li>
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate, anchor: '' %}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</filterable-collection>

{% schema %}
{
  "name": "Filterable collection",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Required when this section is used outside a collection template, such as the homepage."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "default": true,
      "label": "Show Search & Discovery filters"
    },
    {
      "type": "checkbox",
      "id": "show_filter_counts",
      "default": true,
      "label": "Show filter counts"
    },
    {
      "type": "checkbox",
      "id": "show_active_filters",
      "default": true,
      "label": "Show active filter pills"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable sorting"
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "product_count_singular",
      "label": "Product count singular label",
      "default": "product"
    },
    {
      "type": "text",
      "id": "product_count_plural",
      "label": "Product count plural label",
      "default": "products"
    },
    {
      "type": "text",
      "id": "filter_group_label",
      "label": "Filter group accessible label",
      "default": "Product filters"
    },
    {
      "type": "text",
      "id": "clear_filters_label",
      "label": "Clear filters label",
      "default": "Clear filters"
    },
    {
      "type": "text",
      "id": "clear_all_label",
      "label": "Clear active filters label",
      "default": "Clear all"
    },
    {
      "type": "text",
      "id": "remove_filter_label",
      "label": "Remove filter accessible label",
      "default": "Remove filter"
    },
    {
      "type": "text",
      "id": "no_filters_message",
      "label": "No filters message",
      "default": "Add product values and enable filters in Shopify Search & Discovery to show dynamic filters here."
    },
    {
      "type": "text",
      "id": "sort_label",
      "label": "Sort label",
      "default": "Sort by"
    },
    {
      "type": "text",
      "id": "sort_featured_label",
      "label": "Featured sort label",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "sort_price_ascending_label",
      "label": "Price ascending sort label",
      "default": "Price, low to high"
    },
    {
      "type": "text",
      "id": "sort_price_descending_label",
      "label": "Price descending sort label",
      "default": "Price, high to low"
    },
    {
      "type": "text",
      "id": "sort_newest_label",
      "label": "Newest sort label",
      "default": "Newest"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Empty results heading",
      "default": "No products found"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty results text",
      "default": "Try removing a filter or choosing a different sort option."
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading status text",
      "default": "Loading products"
    },
    {
      "type": "text",
      "id": "updated_text",
      "label": "Updated status text",
      "default": "Products updated"
    },
    {
      "type": "text",
      "id": "error_text",
      "label": "Error status text",
      "default": "Unable to update products. Please try again."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Mobile columns",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "adapt",
      "label": "Image ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_shape",
      "default": "default",
      "label": "Image shape",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "round",
          "label": "Round"
        },
        {
          "value": "arch",
          "label": "Arch"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show secondary image"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show rating"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "standard",
      "label": "Quick add",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "bulk",
          "label": "Bulk"
        }
      ]
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Space above section",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Filterable collection"
    }
  ]
}
{% endschema %}
